<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  이 파일은 JavaGen이 치환하는 템플릿입니다.
  - 패키지/모듈 경로: "com.basic.admin.sample" → JavaGen이 동적 패키지로 치환
  - 네임스페이스 접미사: "Template" → JavaGen이 service_name(예: Board, RankingGrp)으로 치환
  - SQL 내부 토큰:
      table_           : 실제 테이블명
      columns_         : SELECT 컬럼 목록
      columnsAdd_      : INSERT 컬럼 목록
      values_          : INSERT VALUES 바인딩
      columnUpdate_    : UPDATE SET 절 (동적 <if>)
      columnId_        : PK 컬럼명 (대문자)
      valueId_         : #{pkField} 바인딩 (카멜케이스)
  - parameter/result 타입: 모두 HashMap 기반 (MyBatis alias "hashmap")
-->

<mapper namespace="com.basic.admin.sample.Template">

    <sql id="whereTemplate">
        <!-- 
        동적 검색 조건 템플릿 (필요 시 활성화)

        <choose>
            <when test='id != null and id != "" '>

            </when>
            <otherwise>

            </otherwise>
        </choose>

        <if test="searchField != null and searchText != null and searchField != '' and searchText != ''">
            <choose>
                <when test='searchField == "title"'>
                    AND TITLE LIKE CONCAT('%', #{searchText}, '%')
                </when>
                <when test='searchField == "content"'>
                    AND CONTENT LIKE CONCAT('%', #{searchText}, '%')
                </when>
                <when test='searchField == "writer"'>
                    AND WRITER LIKE CONCAT('%', #{searchText}, '%')
                </when>
                <otherwise>
                </otherwise>
            </choose>
        </if>
        -->
    </sql> 

    <select id="selectTemplateList" parameterType="hashmap" resultType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.selectTemplateList
         Description : 목록 Query 
        */
        SELECT
            columns_
        FROM table_
        <where>
            <include refid="whereTemplate" />
        </where>
        ORDER BY columnId_ DESC
        <if test="limit != null and offset != null">
            /*  페이징 하단 시작  */
            LIMIT #{limit} OFFSET #{offset}
            /*  페이징 하단 끝  */
        </if>
    </select>

    <select id="selectTemplateListCount" parameterType="hashmap" resultType="int">
        /*
         SQL ID: com.basic.admin.sample.Template.selectTemplateListCount
         Description : 목록에서 레코드수 Query 
        */
        SELECT
            COUNT(*) CNT
        FROM table_
        <where>
            <include refid="whereTemplate" />
        </where> 
    </select>

    <select id="selectTemplateDetail" parameterType="hashmap" resultType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.selectTemplateDetail
         Description : 상세조회 Query 
        */ 
        SELECT
            columns_
        FROM table_
        WHERE columnId_ = valueId_
    </select>

    <insert id="insertTemplate" parameterType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.insertTemplate
         Description : 등록 Query 
        */
        INSERT INTO table_
        (
            columnsAdd_
        )
        VALUES
        (
            values_
        )
    </insert>

    <update id="updateTemplate" parameterType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.updateTemplate
         Description : 수정 Query 
        */
        UPDATE table_
        <set>
            columnUpdate_
        </set>
        WHERE columnId_ = valueId_
    </update>

    <update id="orderTemplate" parameterType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.orderTemplate
         Description : 정렬 순서 수정
        */
        UPDATE table_ SET
            ORDERS = #{orders}
        WHERE columnId_ = valueId_
    </update>

    <delete id="deleteTemplate" parameterType="hashmap">
        /*
         SQL ID: com.basic.admin.sample.Template.deleteTemplate
         Description : 삭제 Query 
        */
        DELETE FROM table_
        WHERE columnId_ = valueId_
    </delete>

</mapper>